generator client {
  provider = "prisma-client-js"
  // output   = "./__generated__"
}

datasource db {
  provider = "postgresql"
  url = env("MYSQL_URI")
}

model User {
  id String @id @default(uuid())

  email String @unique
  password String

  displayName String @map("display_name")
  picture String? @db.VarChar(500)

  bio String? @db.VarChar(100)
  city String? @db.VarChar(100)
  country String? @db.VarChar(100)
  youtube String? @db.VarChar(100)
  telegram String? @db.VarChar(100)
  vk String? @db.VarChar(100)
  twitter String? @db.VarChar(100)
  instagram String? @db.VarChar(100)

  role UserRole @default(REGULAR)

  isVerified Boolean @default(false) @map("is_verified")
  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")

  method AuthMethod

  accounts Account[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  score     Int      @default(0) // Баллы за угаданные бои
  votes     Vote[]   // Связь с голосами пользователя
  lastScoreAt    DateTime @default(now()) @map("last_score_at")

  @@map("users")
}

model Account {
  id String @id @default(uuid())

  type String
  provider String

  refreshToken String? @db.Text @map("refresh_token")
  accessToken String? @db.Text @map("access_token")
  expiresAt Int @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  @@map("accounts")
}

model Token {
  id String @id @default(uuid())

  email String
  token String @unique
  type TokenType
  expiresIn DateTime @map("expires_in")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tokens")
}

// Модель самого Голосования (Боя)
model Poll {
  id          String     @id @default(uuid())
  questionRu  String     @default("") // Например: "Кто победит: Боец 1 или Боец 2?" (русская версия)
  questionEn  String     @default("") // Английская версия вопроса
  status      PollStatus @default(OPEN)
  createdAt   DateTime   @default(now()) @map("created_at")
  expiresAt   DateTime   @map("expires_at") // Когда закрывается голосование

  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String?     @map("tournament_id")
  
  options     Option[]   // Варианты ответов
  votes       Vote[]     // Все голоса в этом опросе
  
  winnerOption   Option?   @relation("PollWinner", fields: [winnerOptionId], references: [id], onDelete: SetNull)
  winnerOptionId String?   @map("winner_option_id") // ID победившего варианта
  isPeopleChamp  Boolean   @default(false) @map("is_people_champ") // Флаг "Народный чемпион"

  @@map("polls")
  @@index([tournamentId])
  @@index([winnerOptionId])
  @@index([expiresAt])
}

// Варианты ответа
model Option {
  id      String  @id @default(uuid())
  textRu  String  @default("") @db.VarChar(200) // Имя бойца (русская версия)
  textEn  String  @default("") @db.VarChar(200) // Имя бойца (английская версия)
  photoUrl String? @db.VarChar(500) // URL-адрес фотографии бойца (опционально)
  
  poll    Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId  String @map("poll_id")
  
  votes   Vote[] // Кто проголосовал именно за этот вариант
  winnerPolls Poll[] @relation("PollWinner")

  @@map("options")
  @@index([pollId])
}

// Факт голосования (чтобы один юзер не голосовал дважды)
model Vote {
  id        String   @id @default(uuid())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String   @map("poll_id")
  
  option    Option   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId  String   @map("option_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, pollId])
  @@map("votes")
}

model Tournament {
  id            String   @id @default(uuid())
  nameRu        String   @default("") @db.VarChar(200) // Например: "UFC 300: Pereira vs Hill" (русская версия)
  nameEn        String   @default("") @db.VarChar(200) // Английская версия названия
  descriptionRu String?  @db.VarChar(1000) // Краткое инфо (русская версия)
  descriptionEn String?  @db.VarChar(1000) // Краткое инфо (английская версия)
  date          DateTime // Дата проведения
  createdAt     DateTime @default(now()) @map("created_at")
  
  polls         Poll[]   // Связь: один турнир — много боев/голосований

  @@map("tournaments")
  @@index([date])
  @@index([createdAt])
}

model News {
  id         String   @id @default(uuid())
  titleRu    String   @default("") @db.VarChar(200) // Заголовок новости (русская версия)
  titleEn    String   @default("") @db.VarChar(200) // Заголовок новости (английская версия)
  contentRu  String   @default("") @db.Text // Текст новости (русская версия)
  contentEn  String   @default("") @db.Text // Текст новости (английская версия)
  imageUrl   String?  @db.VarChar(500) // URL изображения (опционально)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("news")
  @@index([createdAt])
}

enum UserRole {
  REGULAR
  ADMIN
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
  YANDEX
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

enum PollStatus {
  OPEN
  CLOSED
  FINISHED
}